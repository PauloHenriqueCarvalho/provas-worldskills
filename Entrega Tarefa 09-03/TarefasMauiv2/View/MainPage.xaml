<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TarefasMauiv2.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25" 
            VerticalOptions="Center"
            >
            <Image
                Source="logo.png"
                WidthRequest="300"

                Aspect="AspectFit" IsOpaque="False" />

            <Label
                Text="Login"
                Style="{StaticResource Headline}" />

            <Entry Placeholder="Login" x:Name="txtLogin" WidthRequest="300" HorizontalOptions="Center"/>
            <Entry Placeholder="Senha" IsPassword="True" x:Name="txtSenha" WidthRequest="300" HorizontalOptions="Center"/>

            <Button
                Text="Login" 
                Clicked="OnEntrar"
                WidthRequest="300" HorizontalOptions="Center" />
            <Button
                Text="Cadastrar-se" 
                Clicked="OnEntrar"
                HorizontalOptions="Center"
                WidthRequest="300" />
        </VerticalStackLayout>
    </ScrollView>


</ContentPage>
